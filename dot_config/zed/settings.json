{
  "agent_servers": {
    "opencode": {
      "type": "registry"
    },
    "codex-acp": {
      "type": "registry",
    },
  },
  "icon_theme": "Zed (Default)",
  "buffer_font_weight": 500.0,
  "on_last_window_closed": "quit_app",
  "when_closing_with_no_tabs": "close_window",
  "edit_predictions": {
    "open_ai_compatible_api": {
      "api_url": ""
    },
    "ollama": {
      "model": "qwen2.5-coder:7b-base"
    },
    "provider": "ollama",
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "base_keymap": "VSCode",
  "preview_tabs": {
    "enabled": false,
    "enable_preview_from_file_finder": false,
  },
  "tab_bar": {
    "show": true,
  },
  "tabs": {
    "close_position": "right",
  },
  "search": {
    "include_ignored": true,
  },
  "relative_line_numbers": "enabled",
  "vertical_scroll_margin": 8.0,
  "scroll_beyond_last_line": "off",
  "gutter": {
    "line_numbers": true,
  },
  "minimap": {
    "show": "never",
  },
  "cursor_shape": "block",
  "autosave": "on_focus_change",
  "show_completions_on_input": true,
  "show_whitespaces": "boundary",
  "ensure_final_newline_on_save": true,
  "indent_guides": {
    "enabled": true,
  },
  "wrap_guides": [80, 120],
  "soft_wrap": "none",
  "hard_tabs": false,
  "tab_size": 2,
  "context_servers": {
    "mcp-server-context7": {
      "enabled": true,
      "remote": false,
      "settings": {
        "context7_api_key": "CONTEXT7_API_KEY"
      }
    },
    "browser-tools-context-server": {
      "enabled": true,
      "settings": {},
    },
  },
  "toolbar": {
    "quick_actions": false,
  },
  "show_edit_predictions": true,
  "terminal": {
    "blinking": "on",
    "cursor_shape": "block",
    "font_family": "FiraCode Nerd Font",
    "font_size": 14.0,
    "shell": "system",
    "env": {
      "ZED_TERMINAL": "1",
    },
    "line_height": { "custom": 1.25 },
  },
  "project_panel": {
    "auto_fold_dirs": false,
    "auto_reveal_entries": true,
    "dock": "left",
    "indent_size": 12,
  },
  "agent": {
    "tool_permissions": {
      "default": "allow",
    },
    "play_sound_when_agent_done": "always",
    "inline_assistant_model": {
      "provider": "copilot_chat",
      "model": "gpt-5",
    },
    "model_parameters": [],
    "default_model": {
      "provider": "copilot_chat",
      "model": "gpt-5",
    },
  },
  "vim_mode": true,
  "vim": {
    "toggle_relative_line_numbers": true,
    "use_smartcase_find": true,
  },
  "ui_font_size": 16,
  "buffer_font_size": 20.0,
  "agent_ui_font_size": 16,
  "ui_font_family": "JetBrainsMono Nerd Font",
  "buffer_font_family": "FantasqueSansM Nerd Font",
  "theme": {
    "mode": "dark",
    "light": "Ayu Light",
    "dark": "Ayu Dark",
  },
  "diagnostics": {
    "inline": {
      "enabled": true,
    },
  },
}
